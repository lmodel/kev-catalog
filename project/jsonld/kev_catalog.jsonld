    {
      "name": "due_date",
      "definition_uri": "https://w3id.org/lmodel/kev-catalog/due_date",
      "description": "The date (YYYY-MM-DD) by which federal civilian executive branch (FCEB) agencies must remediate the vulnerability per BOD 22-01.",
      "comments": [
        "Deadline set by CISA. Under BOD 19-02, internet-accessible critical vulnerabilities (CVSS >9.0) must be remediated within 15 calendar days and high vulnerabilities (7.0-9.0) within 30 calendar days of initial detection; BOD 22-01 due dates may be tighter and apply to all agency systems, not only internet-accessible ones."
      ],
      "from_schema": "https://w3id.org/lmodel/kev-catalog",
      "aliases": [
        "dueDate"
      ],
      "slot_uri": "https://w3id.org/lmodel/kev-catalog/due_date",
